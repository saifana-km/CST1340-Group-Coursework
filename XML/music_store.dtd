<!ELEMENT Artist (#PCDATA)>
<!ELEMENT Genre (#PCDATA)>
<!ELEMENT VinylPrice (#PCDATA)>

<!-- CUSTOMER -->
<!ELEMENT Customer (CustomerID, CustomerName, Email, Phone)>
<!ELEMENT CustomerID (#PCDATA)>
<!ELEMENT CustomerName (#PCDATA)>
<!ELEMENT Email (#PCDATA)>
<!ELEMENT Phone (#PCDATA)>

<!-- EMPLOYEE -->
<!ELEMENT Employee (EmployeeID, EmployeeName, Role)>
<!ELEMENT EmployeeID (#PCDATA)>
<!ELEMENT EmployeeName (#PCDATA)>
