<!ELEMENT MusicStore (Instrument*, Vinyl*, Customer*, Employee*)>

<!-- INSTRUMENT -->
<!ELEMENT Instrument (InstrumentID, InstrumentName, Brand, InstrumentPrice)>
<!ELEMENT InstrumentID (#PCDATA)>
<!ELEMENT InstrumentName (#PCDATA)>
<!ELEMENT Brand (#PCDATA)>
<!ELEMENT InstrumentPrice (#PCDATA)>

<!-- VINYL -->
<!ELEMENT Vinyl (VinylID, Title, Artist, Genre, VinylPrice)>
<!ELEMENT VinylID (#PCDATA)>
